{
  "name": "bookmarks",
  "description": "Bookmarks collection",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Massimo Cassandro",
  "type": "module",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "start_php_server": "php -S 127.0.0.1:3010 # -t public/",
    "UPD-version": "npx update-version",
    "upd@m": "npx upd@m"
  },
  "browserslist": [
    "last 1 version",
    "iOS >= 13",
    "Safari >= 12",
    "not ie <= 11",
    "> 3% in IT"
  ],
  "stylelint": {
    "extends": "@massimo-cassandro/linters-config/stylelintrc.js",
    "ignoreFiles": [
      "public/**/*.css"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "./node_modules/@massimo-cassandro/linters-config/eslintrc.js"
    ],
    "ignorePatterns": [
      "public/**/*.js"
    ]
  },
  "dependencies": {
    "@fontsource/montagu-slab": "^5.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^6.14.1",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@massimo-cassandro/dev-utilities": "^1.17.2",
    "@massimo-cassandro/linters-config": "^1.4.5",
    "sqlite3": "^5.1.6"
  }
}
